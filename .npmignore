# ─────────────────────────────────────────────
#  .npmignore — files NOT included in the npm tarball
#
#  Note: package.json `"files": ["dist", "README.md",
#  "README.es.md", "LICENSE"]` is the source of truth.
#  This file is a safety net in case "files" is removed.
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
#  Source code (only ship the build)
# ─────────────────────────────────────────────
src/
tests/
__tests__/
test/
examples/
demo/
scripts/

# ─────────────────────────────────────────────
#  Config files
# ─────────────────────────────────────────────
.github/
.vscode/
.idea/
.husky/
*.config.js
*.config.ts
*.config.cjs
*.config.mjs
tsconfig*.json
jest.config.*
tsup.config.*
.eslintrc*
.prettierrc*
.prettierignore
.editorconfig
.gitignore
.gitattributes

# ─────────────────────────────────────────────
#  Documentation (whitelist what ships)
# ─────────────────────────────────────────────
*.md
!README.md
!README.es.md
!CHANGELOG.md
!LICENSE
!LICENSE.md

docs/
docs-site/
.readme/

# ─────────────────────────────────────────────
#  Media (videos and screenshots stay on GitHub)
# ─────────────────────────────────────────────
media/
*.mp4
*.mov
*.gif

# ─────────────────────────────────────────────
#  CI / CD
# ─────────────────────────────────────────────
.travis.yml
.gitlab-ci.yml
.circleci/
codecov.yml
.codecov.yml
azure-pipelines.yml

# ─────────────────────────────────────────────
#  Build artifacts and caches
# ─────────────────────────────────────────────
coverage/
.nyc_output/
*.tsbuildinfo
.cache/
.parcel-cache/
.turbo/
.eslintcache

# ─────────────────────────────────────────────
#  Logs and runtime
# ─────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────
#  OS files
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────
#  Environment
# ─────────────────────────────────────────────
.env
.env.*

# ─────────────────────────────────────────────
#  Other
# ─────────────────────────────────────────────
*.tgz
__snapshots__/
.test-output/