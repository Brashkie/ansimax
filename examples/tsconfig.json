{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "rootDir": ".",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["./**/*.ts", "./**/*.js"],
  "exclude": ["../node_modules", "../dist"]
}
